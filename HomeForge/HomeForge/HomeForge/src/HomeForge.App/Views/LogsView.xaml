<UserControl x:Class="HomeForge.App.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Reports and logs" FontSize="20" FontWeight="SemiBold"  Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Open HomeForge reports, service logs and connection profiles." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,16" />
                <WrapPanel>
                    <Button Content="Open logs" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="OpenLogs_Click" />
                    <Button Content="Open reports" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="OpenReports_Click" />
                    <Button Content="Open connection profiles" Style="{StaticResource SecondaryButton}" Click="OpenConnections_Click" />
                </WrapPanel>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <TextBox x:Name="InfoBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="HomeForge stores reports, logs and connection profiles under C:\HomeServer." />
        </Border>
    </Grid>
</UserControl>
