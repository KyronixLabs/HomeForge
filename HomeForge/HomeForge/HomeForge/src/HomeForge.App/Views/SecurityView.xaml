<UserControl x:Class="HomeForge.App.Views.SecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Public access policy" FontSize="20" FontWeight="SemiBold"  Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Only expose the API or reverse proxy endpoint. Do not expose database ports, workers, logs, backups, admin dashboards or secrets." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <UniformGrid Columns="2">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Recommended" Foreground="{StaticResource SuccessBrush}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="HTTPS public URL → API on localhost" TextWrapping="Wrap" Margin="0,10,0,0"  Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Tailscale Funnel or reverse proxy" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Do not expose" Foreground="{StaticResource DangerBrush}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Opening database, worker or admin ports to the internet" TextWrapping="Wrap" Margin="0,10,0,0"  Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Direct RDP exposure is especially risky" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
