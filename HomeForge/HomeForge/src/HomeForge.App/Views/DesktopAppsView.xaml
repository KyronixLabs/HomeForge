<UserControl x:Class="HomeForge.App.Views.DesktopAppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Application folders" FontSize="20" FontWeight="SemiBold"  Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Place each hosted application in its own folder. HomeForge scans the folders and identifies launch options." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,16" />
                <WrapPanel>
                    <Button Content="Open application folder" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="OpenDropZone_Click" />
                    <Button Content="Rescan" Style="{StaticResource SecondaryButton}" Click="Scan_Click" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="FolderText" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12" />
                <DataGrid x:Name="AppsGrid" Grid.Row="1" AutoGenerateColumns="False" Background="#0B111A" Foreground="{StaticResource TextBrush}" GridLinesVisibility="None" RowBackground="#0E1520" AlternatingRowBackground="#111B29" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="App" Binding="{Binding Name}" Width="180" />
                        <DataGridTextColumn Header="Launcher" Binding="{Binding LauncherHint}" Width="*" />
                        <DataGridCheckBoxColumn Header="Approved" Binding="{Binding Approved}" Width="100" />
                        <DataGridTextColumn Header="Folder" Binding="{Binding FolderPath}" Width="260" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
